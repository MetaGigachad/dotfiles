{
	"layer": "top",
	"modules-left": ["sway/workspaces"],
	"modules-center": [],
	"modules-right": ["tray", "sway/language", "network", "pulseaudio", "battery", "clock"],
    "sway/language": {
        "format": "  {short}",
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "format": "{:<b>%b %d</b> %H:%M}",
    },
	"mpd": {
		"tooltip": false,
		"format": "{stateIcon} {artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S})",
		"format-disconnected": "ﳌ",
		"format-stopped": "",
        "state-icons": {
            "playing": "",
            "paused": ""
        }
	},
	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 5,
		"format": "{icon} {volume}%",
        "format-bluetooth": " {volume}%",
        "format-muted":"{volume}% ﱝ",
		"format-icons": {
			"default": ["奄", "奔", "墳"],
            "headphones": [""],
		}
	},
	"network": {
		"tooltip": false,
		"format-wifi": "  {essid} {ipaddr}",
		"format-ethernet": " {ipaddr}"
	},
	"cpu": {
		"tooltip": false,
		"format": " {}%"
	},
	"memory": {
		"tooltip": false,
		"format": " {}%"
	},
    "battery": {
        "format": "{icon}  {capacity}%",
        "format-charging": "{capacity}% ﮣ",
        "format-icons": ["", "", "", "", ""]
    },
    "sway/workspaces": {
        "format": "{icon}",
        "on-click": "activate"
    }
}
